{
  "name": "yec-gilam-server",
  "version": "2.0.0",
  "description": "YEC Gilam Backend API - Prisma 7 + PostgreSQL (Neon)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "db:push": "npx prisma db push --config=./prisma/prisma.config.ts",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "postinstall": "npx prisma generate --schema=./prisma/schema.prisma",
    "vercel-build": "npx prisma generate --schema=./prisma/schema.prisma"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
